<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#ffffff">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_template_editor_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Редактор шаблонов"
            android:textSize="18sp"
            android:textColor="#0b1a2f"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_template_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:text="✕"
            android:textColor="#6f85a5"
            android:textSize="18sp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Название шаблона"
        android:textSize="14sp"
        android:textColor="#3a4f6e"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_template_name"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:padding="8dp"
        android:background="#f5f7fb"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Текст шаблона (используйте {{Переменная}})"
        android:textSize="14sp"
        android:textColor="#3a4f6e"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_template_text"
    <CheckBox
        android:id="@+id/cb_template_common"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Общий шаблон (доступен всем отделам)"
        android:layout_marginBottom="12dp" />
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:background="#f5f7fb"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:minHeight="150dp"
        android:gravity="top"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Вставить переменную:"
        android:textSize="12sp"
        android:textColor="#6f85a5"
        android:layout_marginBottom="8dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:id="@+id/ll_variable_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp" />

    </HorizontalScrollView>

    <Button
        android:id="@+id/btn_template_save"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#0b1a2f"
        android:text="Сохранить шаблон"
        android:textColor="#ffffff"
        android:textSize="15sp" />

</LinearLayout>
