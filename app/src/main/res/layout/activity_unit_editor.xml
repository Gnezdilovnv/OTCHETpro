<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#ffffff">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_unit_editor_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Расчёты подразделения"
            android:textSize="18sp"
            android:textColor="#0b1a2f"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_unit_editor_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:text="✕"
            android:textColor="#6f85a5"
            android:textSize="18sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_unit_dept_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Подразделение: "
        android:textSize="13sp"
        android:textColor="#3a4f6e"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/et_new_unit"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Название расчёта"
            android:padding="8dp"
            android:background="#f5f7fb"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_add_unit"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/btn_primary"
            android:text="➕ Добавить"
            android:textColor="#ffffff"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_units"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/tv_units_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Нет расчётов.\nДобавьте расчёт для этого подразделения."
        android:textSize="14sp"
        android:textColor="#8a9bb8"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>
