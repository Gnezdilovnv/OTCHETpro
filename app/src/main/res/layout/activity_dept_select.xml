<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#ffffff">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Боевой журнал"
        android:textSize="24sp"
        android:textColor="#0b1a2f"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Выберите подразделение"
        android:textSize="14sp"
        android:textColor="#6f85a5"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_dept_bpla"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/btn_primary"
        android:text="БпЛА"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_dept_minomet"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/btn_primary"
        android:text="Миномет"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_dept_artillery"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/btn_primary"
        android:text="Артиллерия"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_dept_tanks"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/btn_primary"
        android:text="Танки"
        android:textColor="#ffffff"
        android:textSize="16sp" />

</LinearLayout>
